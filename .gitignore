# ══════════════════════════════════════════════════════════════
# DFIR Automation Tool — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── Virtual environment ───────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Forensic images — NEVER commit these ─────────────────────
# Images can be GBs in size and may contain sensitive evidence
data/images/
*.e01
*.E01
*.dd
*.raw
*.img
*.vmdk
*.vhd
*.001
*.aff

# ── Autopsy cases — generated output ─────────────────────────
# Cases are large, machine-specific, and auto-regenerated
data/cases/

# ── Extracted and normalized data ────────────────────────────
# All generated by the pipeline — not source code
data/extracted/
data/normalized/

# ── Vector store and embeddings ───────────────────────────────
ai/embeddings/store/
ai/rag/index/
*.faiss
*.bin
*.npy
vector_store.db

# ── Databases ─────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ── Hash baselines ────────────────────────────────────────────
*.hash
*.hash.tmp
data/hashes/

# ── Custody and audit logs — generated per run ───────────────
docs/custody_log.jsonl
docs/custody_report.md
docs/investigation_report.txt

# ── Environment variables and secrets ─────────────────────────
.env
.env.*
.env.local
.env.production
*.key
secrets.json
credentials.json

# ── VS Code ───────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json

# ── OS noise ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
ehthumbs.db
*~

# ── Testing and coverage ──────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ──────────────────────────────────────────────────────
*.log
*.log.*
logs/

# ── Temp & debug files ──────────────────────────────────────
*.tmp
*.bak
*.swp
*.swo
hashes.txt
verify_env.py
check_db.py
check_artifacts.py
check_structure.py

# ── Model weights and large AI files ─────────────────────────
# sentence-transformers downloads models locally
*.pkl
*.pt
*.pth
*.ckpt
ai/embeddings/models/
.cache/

# ── Tools — binaries, not source code ────────────────────────
# Keep folder structure but ignore executables
tools/zimmerman/PECmd/*.exe
tools/zimmerman/PECmd/*.dll
tools/zimmerman/JLECmd/*.exe
tools/zimmerman/JLECmd/*.dll
tools/chainsaw/chainsaw/*.exe
tools/dotnet*

# ── Reports ───────────────────────────────────────────────────
docs/reports/
*.pdf